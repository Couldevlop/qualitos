# =============================================================================
# QualitOS — variables d'environnement locales (modèle)
#
# Copier vers `.env` (ignoré par git — JAMAIS committé) et remplir.
# Règle §18.2.3 : aucun secret en clair dans le repo. En CI : Actions Secrets ;
# en K8s : Vault + External Secrets Operator ; fichiers versionnés : SOPS.
# =============================================================================

# --- Passerelle IA (AIProvider) — fournisseur par défaut + clés (optionnel) ----
# Provider par défaut quand la requête n'en précise pas : ollama | mistral | anthropic.
# Défaut = ollama (local, souverain, aucune donnée ne sort). Pour basculer toute l'IA
# texte (chat NLQ, suggestions, génération de docs…), poser le provider + sa clé :
#   AI_DEFAULT_PROVIDER=mistral   + MISTRAL_API_KEY=...
#   AI_DEFAULT_PROVIDER=anthropic + ANTHROPIC_API_KEY=...
# (valeur inconnue/absente → repli sûr sur ollama). Aucune autre modif de code.
AI_DEFAULT_PROVIDER=ollama
# Laisser les clés vides pour utiliser Ollama local uniquement.
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=
# Modèles des providers hébergés (optionnel — défauts ci-dessous si absent).
# NLQ/text-to-SQL : un modèle code-tuné ou rapide suffit (ex. codestral-latest côté
# Mistral, claude-haiku/sonnet côté Anthropic) — inutile de payer un opus pour du SQL.
MISTRAL_MODEL=mistral-large-latest
ANTHROPIC_MODEL=claude-opus-4-7

# --- Hyperledger Fabric (blockchain-service) — chemins des credentials --------
# Pointent vers des fichiers LOCAUX (hors repo). Voir docs/runbooks.
FABRIC_PEER_ENDPOINT=
FABRIC_PEER_HOST_ALIAS=
FABRIC_MSP_ID=
FABRIC_MSP_DIR=
FABRIC_CHANNEL=
FABRIC_CHAINCODE=
FABRIC_CERT=
FABRIC_KEY=
FABRIC_TLS_CERT=

# --- NB ------------------------------------------------------------------------
# Les identifiants des docker-compose dev (admin/admin, postgres "qualitos")
# sont des valeurs DEV locales assumées, sans rapport avec un environnement
# déployé. Ne jamais reproduire ce pattern en staging/prod.
