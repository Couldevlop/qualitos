# =============================================================================
# QualitOS — variables d'environnement locales (modèle)
#
# Copier vers `.env` (ignoré par git — JAMAIS committé) et remplir.
# Règle §18.2.3 : aucun secret en clair dans le repo. En CI : Actions Secrets ;
# en K8s : Vault + External Secrets Operator ; fichiers versionnés : SOPS.
# =============================================================================

# --- Passerelle IA (AIProvider) — clés des fournisseurs externes (optionnel) --
# Laisser vide pour utiliser Ollama local uniquement.
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=

# --- Hyperledger Fabric (blockchain-service) — chemins des credentials --------
# Pointent vers des fichiers LOCAUX (hors repo). Voir docs/runbooks.
FABRIC_PEER_ENDPOINT=
FABRIC_PEER_HOST_ALIAS=
FABRIC_MSP_ID=
FABRIC_MSP_DIR=
FABRIC_CHANNEL=
FABRIC_CHAINCODE=
FABRIC_CERT=
FABRIC_KEY=
FABRIC_TLS_CERT=

# --- NB ------------------------------------------------------------------------
# Les identifiants des docker-compose dev (admin/admin, postgres "qualitos")
# sont des valeurs DEV locales assumées, sans rapport avec un environnement
# déployé. Ne jamais reproduire ce pattern en staging/prod.
