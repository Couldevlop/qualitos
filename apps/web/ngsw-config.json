{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": ["/favicon.ico", "/index.html", "/manifest.webmanifest", "/*.css", "/*.js"]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": ["/assets/**", "/media/**"]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "api-fives-read",
      "urls": ["/api/v1/fives/**"],
      "cacheConfig": {
        "strategy": "freshness",
        "timeout": "4s",
        "maxSize": 100,
        "maxAge": "1d"
      }
    },
    {
      "name": "api-read-misc",
      "urls": ["/api/v1/kpi/**", "/api/v1/standards/**"],
      "cacheConfig": {
        "strategy": "freshness",
        "timeout": "4s",
        "maxSize": 100,
        "maxAge": "12h"
      }
    }
  ],
  "navigationUrls": ["/**", "!/**/*.*", "!/**/*__*", "!/**/*__*/**"]
}
